{
  "name": "slice-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-with-env.mjs \"npx tsx watch src/index.ts\"",
    "build": "tsc",
    "start": "node scripts/run-with-env.mjs \"node dist/index.js\"",
    "db:migrate": "node scripts/run-with-env.mjs \"npx prisma migrate dev\"",
    "db:deploy": "node scripts/run-with-env.mjs \"npx prisma migrate deploy\"",
    "db:seed": "node scripts/run-with-env.mjs \"npx tsx prisma/seed.ts\"",
    "db:studio": "node scripts/run-with-env.mjs \"npx prisma studio\"",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\""
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
