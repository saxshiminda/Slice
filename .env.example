# Server
# Local Postgres on default port:
# DATABASE_URL=postgresql://slice:slice@localhost:5432/slice_db
# Docker Compose exposes Postgres on host port 5433:
DATABASE_URL=postgresql://slice:slice@localhost:5433/slice_db
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development
# STATIC_DIR=../client/dist   # set in production to serve built client from Express
JWT_SECRET=slice-dev-secret-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123

# Customer auth (separate from admin JWT)
CUSTOMER_JWT_SECRET=slice-customer-dev-secret-change-in-production

# Email — Resend (https://resend.com)
# Leave blank to log emails to console in development
# RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Slice Bakery <noreply@yourdomain.com>
EMAIL_BAKERY=owner@yourbakery.com

# Payment — BoG iPay v2 (Bank of Georgia)
# Leave blank to run in mock mode (payment is auto-confirmed for testing)
# BOG_CLIENT_ID=your_client_id
# BOG_CLIENT_SECRET=your_client_secret
# Set to false to force real payment even without credentials (will fail without them)
BOG_MOCK_PAYMENT=true

# Site configuration (can also be changed via admin panel)
# SITE_MODE=both   # "retail" | "bespoke" | "both"

# Client
VITE_API_URL=http://localhost:3001
# VITE_API_URL=              # leave empty in production when API is same-origin
