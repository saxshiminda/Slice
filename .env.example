# Server
# Local Postgres on default port:
# DATABASE_URL=postgresql://slice:slice@localhost:5432/slice_db
# Docker Compose exposes Postgres on host port 5433:
DATABASE_URL=postgresql://slice:slice@localhost:5433/slice_db
PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development
# STATIC_DIR=../client/dist   # set in production to serve built client from Express
JWT_SECRET=slice-dev-secret-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123

# Client
VITE_API_URL=http://localhost:3001
# VITE_API_URL=              # leave empty in production when API is same-origin
